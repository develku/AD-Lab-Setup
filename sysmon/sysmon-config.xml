<!--
  AD-Lab SOC Monitoring Configuration
  Version: 1.0
  Based on: SwiftOnSecurity sysmon-config (https://github.com/SwiftOnSecurity/sysmon-config)
  Purpose: Tuned for SOC analyst training in AD lab environment

  This configuration focuses on high-value telemetry for threat detection
  while filtering out common noise. Each rule group includes comments
  referencing the MITRE ATT&CK techniques it helps detect.

  Event IDs covered: 1, 3, 7, 8, 10, 11, 12, 13, 14, 15, 22, 25
  Event IDs intentionally excluded: 5 (Process Terminated — high volume, low value)
-->
<Sysmon schemaversion="4.90">
  <HashAlgorithms>md5,sha256,IMPHASH</HashAlgorithms>
  <CheckRevocation>false</CheckRevocation>

  <EventFiltering>

    <!--
    ================================================================
    Event ID 1: Process Creation
    MITRE ATT&CK: T1059 (Command and Scripting Interpreter),
                  T1204 (User Execution), T1569 (System Services)
    Purpose: Log process creation with full command lines. Exclude
    known noisy system processes to keep volume manageable while
    retaining all security-relevant execution events.
    ================================================================
    -->
    <RuleGroup name="ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <!-- Exclude routine Windows telemetry and update noise -->
        <ParentImage condition="is">C:\Windows\System32\svchost.exe</ParentImage>
        <Image condition="is">C:\Windows\System32\conhost.exe</Image>
        <Image condition="is">C:\Windows\System32\wbem\WmiPrvSE.exe</Image>
        <Image condition="is">C:\Windows\System32\backgroundTaskHost.exe</Image>
        <Image condition="is">C:\Windows\System32\SearchProtocolHost.exe</Image>
        <Image condition="is">C:\Windows\System32\SearchFilterHost.exe</Image>
        <Image condition="is">C:\Windows\System32\audiodg.exe</Image>
        <Image condition="is">C:\Windows\System32\RuntimeBroker.exe</Image>
        <Image condition="is">C:\Windows\System32\MusNotifyIcon.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 3: Network Connection
    MITRE ATT&CK: T1071 (Application Layer Protocol),
                  T1572 (Protocol Tunneling), T1041 (Exfiltration Over C2)
    Purpose: Log outbound network connections to detect C2 callbacks,
    lateral movement, and data exfiltration. Exclude common Windows
    update and telemetry destinations to reduce noise.
    ================================================================
    -->
    <RuleGroup name="NetworkConnect" groupRelation="or">
      <NetworkConnect onmatch="exclude">
        <!-- Exclude standard Windows update and telemetry endpoints -->
        <DestinationHostname condition="end with">.microsoft.com</DestinationHostname>
        <DestinationHostname condition="end with">.windowsupdate.com</DestinationHostname>
        <DestinationHostname condition="end with">.windows.com</DestinationHostname>
        <DestinationHostname condition="end with">.bing.com</DestinationHostname>
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
        <!-- Exclude local DNS resolver traffic -->
        <DestinationPort condition="is">53</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 7: Image Loaded (DLL)
    MITRE ATT&CK: T1055 (Process Injection), T1574 (Hijack Execution Flow),
                  T1547 (Boot or Logon Autostart Execution)
    Purpose: Monitor DLL loads into sensitive processes to detect
    DLL injection, side-loading, and credential theft tooling.
    Only monitor key processes to avoid excessive log volume.
    ================================================================
    -->
    <RuleGroup name="ImageLoad" groupRelation="or">
      <ImageLoad onmatch="include">
        <!-- Monitor DLL loads into credential and scripting processes -->
        <Image condition="is">C:\Windows\System32\lsass.exe</Image>
        <Image condition="is">C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe</Image>
        <Image condition="is">C:\Windows\System32\cmd.exe</Image>
        <Image condition="is">C:\Windows\SysWOW64\WindowsPowerShell\v1.0\powershell.exe</Image>
        <Image condition="is">C:\Windows\System32\wscript.exe</Image>
        <Image condition="is">C:\Windows\System32\cscript.exe</Image>
        <Image condition="is">C:\Windows\System32\mshta.exe</Image>
      </ImageLoad>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 8: CreateRemoteThread
    MITRE ATT&CK: T1055 (Process Injection), T1055.003 (Thread Execution Hijacking)
    Purpose: Log all remote thread creation. This is a critical
    indicator of process injection used by most offensive toolkits
    (Cobalt Strike, Metasploit, Mimikatz).
    ================================================================
    -->
    <RuleGroup name="CreateRemoteThread" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">
        <!-- Exclude known legitimate remote thread sources -->
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\wininit.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\winlogon.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\services.exe</SourceImage>
      </CreateRemoteThread>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 10: Process Access
    MITRE ATT&CK: T1003 (OS Credential Dumping), T1003.001 (LSASS Memory)
    Purpose: Detect access to LSASS process memory, which is the
    primary target for credential dumping tools like Mimikatz,
    ProcDump, and comsvcs.dll MiniDump.
    ================================================================
    -->
    <RuleGroup name="ProcessAccess" groupRelation="or">
      <ProcessAccess onmatch="include">
        <!-- Alert on any process accessing LSASS memory -->
        <TargetImage condition="is">C:\Windows\System32\lsass.exe</TargetImage>
      </ProcessAccess>
      <ProcessAccess onmatch="exclude">
        <!-- Exclude known safe callers that legitimately access LSASS -->
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\lsass.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\wininit.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\LogonUI.exe</SourceImage>
        <SourceImage condition="is">C:\Program Files\Windows Defender\MsMpEng.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\svchost.exe</SourceImage>
      </ProcessAccess>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 11: File Created
    MITRE ATT&CK: T1105 (Ingress Tool Transfer), T1036 (Masquerading),
                  T1059 (Command and Scripting Interpreter)
    Purpose: Monitor file creation in directories commonly used by
    attackers to stage tools and malware (Downloads, AppData, Temp,
    System32). Exclude log rotation and Windows update noise.
    ================================================================
    -->
    <RuleGroup name="FileCreate" groupRelation="or">
      <FileCreate onmatch="include">
        <!-- Monitor common malware staging directories -->
        <TargetFilename condition="contains">\Users\</TargetFilename>
        <TargetFilename condition="contains">\Downloads\</TargetFilename>
        <TargetFilename condition="contains">\AppData\</TargetFilename>
        <TargetFilename condition="contains">\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Windows\System32\</TargetFilename>
        <!-- Detect executable files dropped anywhere -->
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.dll</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.vbs</TargetFilename>
        <TargetFilename condition="end with">.js</TargetFilename>
        <TargetFilename condition="end with">.hta</TargetFilename>
        <TargetFilename condition="end with">.scr</TargetFilename>
      </FileCreate>
      <FileCreate onmatch="exclude">
        <!-- Exclude log rotation and transient system files -->
        <TargetFilename condition="end with">.log</TargetFilename>
        <TargetFilename condition="end with">.etl</TargetFilename>
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
      </FileCreate>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 12: Registry Object Added or Deleted
    Event ID 13: Registry Value Set
    Event ID 14: Registry Object Renamed
    MITRE ATT&CK: T1547.001 (Registry Run Keys / Startup Folder),
                  T1543.003 (Windows Service), T1053.005 (Scheduled Task)
    Purpose: Monitor registry changes to persistence and
    configuration locations used by malware and attackers.
    ================================================================
    -->
    <RuleGroup name="RegistryEvent" groupRelation="or">
      <RegistryEvent onmatch="include">
        <!-- Run keys — most common persistence mechanism (T1547.001) -->
        <TargetObject condition="contains">\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">\CurrentVersion\RunOnce</TargetObject>
        <TargetObject condition="contains">\CurrentVersion\RunOnceEx</TargetObject>

        <!-- Services — malware often installs as services (T1543.003) -->
        <TargetObject condition="contains">\Services\</TargetObject>

        <!-- Scheduled Tasks registry path (T1053.005) -->
        <TargetObject condition="contains">\Schedule\TaskCache\</TargetObject>

        <!-- Image File Execution Options — debugger/ifeo injection (T1546.012) -->
        <TargetObject condition="contains">\Image File Execution Options\</TargetObject>

        <!-- Winlogon persistence locations -->
        <TargetObject condition="contains">\Microsoft\Windows NT\CurrentVersion\Winlogon</TargetObject>

        <!-- AppInit DLLs — DLL injection via registry (T1546.010) -->
        <TargetObject condition="contains">\Windows\CurrentVersion\Windows\AppInit_DLLs</TargetObject>

        <!-- Security package persistence (T1547.005) -->
        <TargetObject condition="contains">\Control\Lsa\Security Packages</TargetObject>
        <TargetObject condition="contains">\Control\Lsa\Authentication Packages</TargetObject>

        <!-- COM object hijacking (T1546.015) -->
        <TargetObject condition="contains">\Classes\CLSID\</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 15: FileCreateStreamHash
    MITRE ATT&CK: T1564.004 (NTFS File Attributes — Alternate Data Streams)
    Purpose: Detect abuse of NTFS Alternate Data Streams (ADS).
    Attackers hide payloads in ADS to evade file-based detection.
    Zone.Identifier streams are excluded as they are standard
    Windows behavior for downloaded files.
    ================================================================
    -->
    <RuleGroup name="FileCreateStreamHash" groupRelation="or">
      <FileCreateStreamHash onmatch="exclude">
        <!-- Zone.Identifier is a normal Mark-of-the-Web stream -->
        <TargetFilename condition="end with">:Zone.Identifier</TargetFilename>
      </FileCreateStreamHash>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 22: DNS Query
    MITRE ATT&CK: T1071.004 (DNS Protocol for C2), T1568 (Dynamic Resolution),
                  T1048 (Exfiltration Over Alternative Protocol)
    Purpose: Log DNS queries to detect C2 over DNS, DGA domains,
    and DNS-based data exfiltration. Exclude common Microsoft and
    Windows domains to reduce noise.
    ================================================================
    -->
    <RuleGroup name="DnsQuery" groupRelation="or">
      <DnsQuery onmatch="exclude">
        <!-- Exclude common Microsoft infrastructure domains -->
        <QueryName condition="end with">.microsoft.com</QueryName>
        <QueryName condition="end with">.msftncsi.com</QueryName>
        <QueryName condition="end with">.msftconnecttest.com</QueryName>
        <QueryName condition="end with">.windows.com</QueryName>
        <QueryName condition="end with">.windowsupdate.com</QueryName>
        <QueryName condition="end with">.bing.com</QueryName>
        <QueryName condition="end with">.office.com</QueryName>
        <QueryName condition="end with">.office365.com</QueryName>
        <QueryName condition="end with">.live.com</QueryName>
        <QueryName condition="end with">.gstatic.com</QueryName>
        <!-- Exclude local domain lookups -->
        <QueryName condition="end with">.lab.local</QueryName>
        <QueryName condition="end with">.in-addr.arpa</QueryName>
      </DnsQuery>
    </RuleGroup>

    <!--
    ================================================================
    Event ID 25: Process Tampering
    MITRE ATT&CK: T1055.012 (Process Hollowing), T1574 (Hijack Execution Flow)
    Purpose: Detect process hollowing and herpaderping — advanced
    evasion techniques where a legitimate process image is replaced
    in memory with malicious code. Log all events (no exclusions).
    ================================================================
    -->
    <RuleGroup name="ProcessTampering" groupRelation="or">
      <ProcessTampering onmatch="exclude">
        <!-- Log all process tampering events — no exclusions.
             These are high-fidelity indicators of advanced attacks. -->
      </ProcessTampering>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
